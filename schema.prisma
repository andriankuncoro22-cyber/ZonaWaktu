// Prisma schema for Sistempakyani ERP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

model Material {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  unit        String   // e.g., kg, gram, pcs
  minStock    Float    @default(0)
  currentStock Float    @default(0)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  price       Decimal
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
